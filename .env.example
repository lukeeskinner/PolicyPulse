# ============================================================================
# PolicyPulse environment configuration
#
# Everything is OPTIONAL. With no keys at all, the app runs fully:
#   - policy parsing falls back to a built-in heuristic engine
#   - resident stories fall back to deterministic templates
#   - demographics come from grounded, labeled datasets
#   - the "nervous system" runs in-memory instead of Redis
#
# Add keys to light up the live integrations.
# Copy this file to `.env.local` and fill in what you have.
# ============================================================================

# --- Mastra agents (Anthropic Claude Haiku) --------------------------------
# Powers the PolicyAnalyst (free-text bill -> structured impact model) and the
# Resident narrator (first-person resident stories).
ANTHROPIC_API_KEY=

# Optional model overrides (defaults shown).
# POLICYPULSE_ANALYST_MODEL=anthropic/claude-haiku-4-5
# POLICYPULSE_RESIDENT_MODEL=anthropic/claude-haiku-4-5

# --- Redis (the "nervous system": Streams / JSON / TimeSeries / Pub-Sub) ----
# Provide a Redis Stack URL to mirror every run into Redis. Without it,
# everything runs in-memory and the app behaves identically.
# REDIS_URL=redis://localhost:6379

# --- Browserbase (live community ingestion) --------------------------------
# When all three are set, ingestion opens a real headless browser session to
# verify live data for the jurisdiction. Requires `npm i playwright-core`.
# BROWSERBASE_API_KEY=
# BROWSERBASE_PROJECT_ID=
# ENABLE_BROWSERBASE=0

# ============================================================================
# LIVE CIVIC PULSE MAP  (the homepage)
# These power the real, no-mock 3D map of bills near you + local news + a
# Census-grounded population. Each surface degrades to an honest empty state
# ("connect this key" / "no results") rather than ever inventing data.
# ============================================================================

# --- Mapbox (3D map + reverse geocoding your area) -------------------------
# Required for the map to render. Free tier ~50k loads/mo. This token is sent
# to the browser (normal for Mapbox) — restrict it by URL in the Mapbox
# dashboard. https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=

# --- Congress.gov (real federal bills) -------------------------------------
# Free key, issued instantly: https://api.congress.gov/sign-up/
CONGRESS_API_KEY=

# --- OpenStates (real state legislature bills) -----------------------------
# Free key: https://open.pluralpolicy.com/accounts/profile/
OPENSTATES_API_KEY=

# --- GNews (real local news for your area) ---------------------------------
# Free tier 100 req/day, works in deployed apps: https://gnews.io/
GNEWS_API_KEY=

# --- U.S. Census (live ACS demographics -> the population) -----------------
# Free key: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# ============================================================================
# GHOST PROTOCOL  (/ghost — a live crisis simulation watched in real time)
#
# Everything below is OPTIONAL. With no keys, Ghost Protocol runs fully:
#   - agents reason with a deterministic policy (Claude lights up via the
#     ANTHROPIC_API_KEY above)
#   - narration uses the browser Web Speech API instead of Deepgram
#   - the world state mirrors to Redis only when REDIS_URL is set
#   - scenario grounding uses pre-seeded CISA/MITRE threat intel unless
#     Browserbase is enabled (BROWSERBASE_* + ENABLE_BROWSERBASE=1 above)
#   - Fetch.ai negotiation, Orkes orchestration, and Arize tracing run as the
#     in-app "native" implementations (the documented hackathon fallbacks)
# ============================================================================

# --- Deepgram Aura (real-time voice narration of agent decisions) ----------
# https://console.deepgram.com/  — falls back to browser speech without a key.
DEEPGRAM_API_KEY=
# DEEPGRAM_TTS_MODEL=aura-2-thalia-en

# --- Ghost agent reasoning model override (defaults to the analyst model) ---
# POLICYPULSE_GHOST_MODEL=anthropic/claude-haiku-4-5

# --- Fetch.ai (flip the negotiation bus from "native" to "live") -----------
# FETCHAI_AGENTVERSE_KEY=

# --- Orkes Conductor (flip orchestration from "native" to "live") ----------
# ORKES_SERVER_URL=
# ORKES_KEY_ID=
# ORKES_KEY_SECRET=

# --- Arize Phoenix (flip tracing from "native" to "live" OTLP export) ------
# ARIZE_API_KEY=
# PHOENIX_COLLECTOR_ENDPOINT=

# --- Simular Agent S3 (computer-use mode instead of structured JSON) -------
# ENABLE_SIMULAR=0

# --- Cognition (autonomous patch generation; armed by default) -------------
# DISABLE_COGNITION=0
