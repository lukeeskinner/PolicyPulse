# ============================================================================
# PolicyPulse environment configuration
#
# Everything is OPTIONAL. With no keys at all, the app runs fully:
#   - policy parsing falls back to a built-in heuristic engine
#   - resident stories fall back to deterministic templates
#   - demographics come from grounded, labeled datasets
#   - the "nervous system" runs in-memory instead of Redis
#
# Add keys to light up the live integrations.
# Copy this file to `.env.local` and fill in what you have.
# ============================================================================

# --- Mastra agents (Anthropic Claude Haiku) --------------------------------
# Powers the PolicyAnalyst (free-text bill -> structured impact model) and the
# Resident narrator (first-person resident stories).
ANTHROPIC_API_KEY=

# Optional model overrides (defaults shown).
# POLICYPULSE_ANALYST_MODEL=anthropic/claude-3-5-haiku-20241022
# POLICYPULSE_RESIDENT_MODEL=anthropic/claude-3-5-haiku-20241022

# --- Redis (the "nervous system": Streams / JSON / TimeSeries / Pub-Sub) ----
# Provide a Redis Stack URL to mirror every run into Redis. Without it,
# everything runs in-memory and the app behaves identically.
# REDIS_URL=redis://localhost:6379

# --- Browserbase (live community ingestion) --------------------------------
# When all three are set, ingestion opens a real headless browser session to
# verify live data for the jurisdiction. Requires `npm i playwright-core`.
# BROWSERBASE_API_KEY=
# BROWSERBASE_PROJECT_ID=
# ENABLE_BROWSERBASE=0
